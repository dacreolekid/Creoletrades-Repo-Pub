/*
  # ── Security ──
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://www.youtube.com; connect-src 'self' https://www.googleapis.com https://formspree.io https://www.youtube.com https://cloudflareinsights.com; upgrade-insecure-requests;
  Cross-Origin-Opener-Policy: same-origin-allow-popups

  # ── Performance: cache everything by default for 1 hour ──
  Cache-Control: public, max-age=3600, must-revalidate

# ── HTML — never cache, always fresh ──
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# ── Images — cache for 1 year (they won't change often) ──
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable

# ── Fonts — cache for 1 year ──
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable

# ── CSS / JS — cache for 1 week ──
/*.css
  Cache-Control: public, max-age=604800, must-revalidate
/*.js
  Cache-Control: public, max-age=604800, must-revalidate

# ── roux-bot.js — short cache so chatbot updates propagate fast ──
/roux-bot.js
  Cache-Control: public, max-age=300, must-revalidate

# ── Audio / Video — cache for 1 year ──
/*.webm
  Cache-Control: public, max-age=31536000, immutable

# ── Princess Trader — allow inline scripts, audio, and mic ──
/academy/princess-trader/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self' blob:; img-src 'self' data:; connect-src 'self'; upgrade-insecure-requests;
  Permissions-Policy: microphone=(self)

# ── 404 page — never cache ──
/404.html
  Cache-Control: no-cache, no-store, must-revalidate
